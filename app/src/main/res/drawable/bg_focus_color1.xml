<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="99dp" />
            <gradient
                android:angle="0"
                android:startColor="#CC7AB1"
                android:centerColor="#CC7AB1"
                android:centerX="0.65"
                android:endColor="#CC7AB1"
                android:type="linear" />
            <padding
                android:bottom="1dp"
                android:left="1dp"
                android:right="1dp"
                android:top="1dp" />
        </shape>
    </item>

    <item>
        <shape>
            <corners android:radius="99dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>