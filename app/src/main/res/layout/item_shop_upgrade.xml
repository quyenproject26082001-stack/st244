<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_shop_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        >

        <ImageView
            android:id="@+id/imgUpgradeIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />


    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvUpgradeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cherry_bomb_regular"
            android:textColor="#004080"
            android:textSize="15sp"
            android:text="Upgrade Name lv.1" />

        <TextView
            android:id="@+id/tvUpgradeDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cherry_bomb_regular"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:text="+5 coins/second" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnBuy"
        android:layout_width="92dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_price_btn"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvBuyPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cherry_bomb_regular"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:text="50" />

        <ImageView
            android:id="@+id/ivCoinIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="2dp"
            android:src="@drawable/ic_coin_progress" />

    </LinearLayout>

</LinearLayout>
