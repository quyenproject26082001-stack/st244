<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:clipChildren="false"
    android:clipToOutline="false"
    android:clipToPadding="false"
    tools:context=".ui.language.LanguageActivity">


    <!-- LANGUAGE title (overlapping card top) -->
    <com.temppp.core.custom.text.DoubleStrokeTextView
        android:id="@+id/tvLang"
        style="@style/single_marquee"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="0dp"
        android:layout_marginTop="56dp"
        android:fontFamily="@font/cherry_bomb_regular"
        android:gravity="center"
        android:paddingStart="10dp"
        android:text="@string/language"
        android:textColor="#7FC0FF"
        android:textSize="32sp"
        app:innerStrokeColor="@color/white"
        app:innerStrokeWidth="3dp"
        app:layout_constraintDimensionRatio="164:40"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:outerStrokeColor="#00407F"
        app:outerStrokeWidth="10dp" />


    <!-- checkmark done button (top-right) -->
    <ImageView
        android:id="@+id/btnDone"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="end"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="20dp"
        android:src="@drawable/ic_done"
        android:tint="@color/pride_btn_active"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@id/tvLang"
        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintTop_toTopOf="@id/tvLang" />

    <!-- rcv -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:orientation="vertical"
        android:overScrollMode="never"
        android:paddingHorizontal="20dp"
        android:paddingBottom="36dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/tvLang"
        tools:listitem="@layout/item_language" />


    <TextView
        android:id="@+id/btnDoneLangSetting"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/ic_done_lang_settings"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@id/tvLang"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvLang" />

    <TextView
        android:id="@+id/btnBackLangSetting"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="24dp"
        android:background="@drawable/ic_back_setting"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@id/tvLang"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvLang" />


</androidx.constraintlayout.widget.ConstraintLayout>
