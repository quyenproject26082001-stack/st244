<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#222222">

    <!-- Top dark bar with call timer -->
    <TextView
        android:id="@+id/tvCallTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:fontFamily="@font/cherry_bomb_regular"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:text="00:00"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Cat image full screen -->
    <ImageView
        android:id="@+id/imgCallCat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_loading"
        app:layout_constraintBottom_toTopOf="@id/hangUpContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCallTimer" />

    <!-- Coins earned during call -->
    <TextView
        android:id="@+id/tvCallCoins"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_coin_progress"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:fontFamily="@font/cherry_bomb_regular"
        android:textColor="#5A3200"
        android:textSize="16sp"
        android:text="+0 coins"
        app:layout_constraintBottom_toTopOf="@id/hangUpContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bottom hang-up area -->
    <FrameLayout
        android:id="@+id/hangUpContainer"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="#333333"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/btnHangUp"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_boost_passive"
            android:padding="16dp"
            android:src="@drawable/ic_done"
            android:tint="#FFFFFF" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
