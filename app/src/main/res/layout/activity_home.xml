<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/bg_home"
    android:clipChildren="false"
    android:clipToOutline="false"
    android:clipToPadding="false">

    <!-- Coin bar -->
    <FrameLayout
        android:id="@+id/coinBarContainer"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="52dp"
        android:background="@drawable/bg_coin_progress"
        android:foreground="@drawable/bg_coin_progress_stroke"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/progressCoins"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFDD33" />


        <com.temppp.core.custom.text.DoubleStrokeTextView
            android:id="@+id/tvCoinCount"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="@font/cherry_bomb_regular"
            android:gravity="center"
            android:text="0 / 100"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:outerStrokeColor="#804D06"
            app:outerStrokeWidth="3dp" />
    </FrameLayout>


    <ImageView
        android:id="@+id/coinIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="-20dp"
        android:elevation="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="@id/coinBarContainer"
        app:layout_constraintTop_toTopOf="@id/coinBarContainer"
        app:layout_constraintBottom_toBottomOf="@id/coinBarContainer"
        android:src="@drawable/ic_coin_progress" />

    <!-- Stats row -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:weightSum="2"
        android:clipChildren="false"
        android:clipToOutline="false"
        android:clipToPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/coinBarContainer">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"

            android:background="@drawable/bg_stat_pill">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_increase"
                android:id="@+id/icIncreaseClick"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="-5dp"
                android:visibility="gone"
                android:layout_marginStart="-5dp"
                />


            <TextView
                android:id="@+id/tvCoinsPerClick"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:fontFamily="@font/cherry_bomb_regular"
                android:gravity="center"
                android:text="10"
                android:textColor="#2ECC71"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/imgCoinPerClick"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/imgCoinPerClick"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_coin_progress"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvCoinsPerClickSP"
                app:layout_constraintStart_toEndOf="@id/tvCoinsPerClick"
                app:layout_constraintTop_toTopOf="parent" />

            <com.temppp.core.custom.text.DoubleStrokeTextView
                android:id="@+id/tvCoinsPerClickSP"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="6dp"

                android:fontFamily="@font/cherry_bomb_regular"
                android:gravity="center"
                android:text="@string/per_click"
                android:textColor="#804D06"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/imgCoinPerClick"
                app:layout_constraintTop_toTopOf="parent" />


        </androidx.constraintlayout.widget.ConstraintLayout>

        <Space
            android:layout_width="8dp"
            android:layout_height="wrap_content" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_stat_pill">


            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_increase"
                android:id="@+id/icIncreaseSecond"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="-5dp"
                android:visibility="gone"
                android:layout_marginStart="-5dp"
                />


            <TextView
                android:id="@+id/tvCoinsPerSecond"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:fontFamily="@font/cherry_bomb_regular"
                android:gravity="center"
                android:text="10"
                android:textColor="#2ECC71"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/imgCoinPerSecond"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/imgCoinPerSecond"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_coin_progress"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvCoinsPerSecondSP"
                app:layout_constraintStart_toEndOf="@id/tvCoinsPerSecond"
                app:layout_constraintTop_toTopOf="parent" />

            <com.temppp.core.custom.text.DoubleStrokeTextView
                android:id="@+id/tvCoinsPerSecondSP"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="6dp"

                android:fontFamily="@font/cherry_bomb_regular"
                android:gravity="center"
                android:text="@string/per_second"
                android:textColor="#804D06"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/imgCoinPerSecond"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>


    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5"
        android:id="@+id/glCenter"/>


    <!-- x2 click boost active label -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutClickBoostClickActive"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintEnd_toEndOf="@id/glCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statsRow">

        <FrameLayout
            android:id="@+id/progressBoostClickContainer"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            android:layout_marginStart="28dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/icX2Click">

            <View
                android:id="@+id/progressBoostClick"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/ic_loading" />

            <View
                android:id="@+id/whiteOverlayClick"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FFFFFF" />
        </FrameLayout>

        <TextView
            android:id="@+id/icX2Click"
            android:layout_width="26dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/ic_x2"
            app:layout_constraintEnd_toEndOf="parent"
            android:textSize="12sp" />
    </androidx.constraintlayout.widget.ConstraintLayout>




    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutClickBoostActiveSecond"
        android:layout_width="0dp"
        android:layout_height="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintStart_toStartOf="@id/glCenter"
        app:layout_constraintTop_toBottomOf="@id/statsRow">

        <FrameLayout
            android:id="@+id/progressBoostSecondContainer"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/icX2Second"
            app:layout_constraintBottom_toBottomOf="parent">

            <View
                android:id="@+id/progressBoostSecond"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/ic_loading" />

            <View
                android:id="@+id/whiteOverlaySecond"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FFFFFF" />
        </FrameLayout>

        <TextView
            android:id="@+id/icX2Second"
            android:layout_width="26dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/ic_x2"
            android:layout_marginEnd="28dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:textSize="12sp" />
    </androidx.constraintlayout.widget.ConstraintLayout>







    <!-- Cat circular frame -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/catFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="56dp"
        app:layout_constraintDimensionRatio="1:1"
        android:layout_marginHorizontal="60dp"
        android:background="@color/transparent"
        android:clipToOutline="true"
        app:cardCornerRadius="999dp"
        app:strokeColor="@color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statsRow">

        <ImageView
            android:id="@+id/imgCat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_loading" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Boost buttons + phone button -->
    <LinearLayout
        android:id="@+id/controlsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/catFrame">

        <!-- x2 click boost -->
        <LinearLayout
            android:id="@+id/btnClickBoost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_boost_click">

            </FrameLayout>


        </LinearLayout>

        <!-- Phone button (main clicker) -->
        <FrameLayout
            android:id="@+id/btnPhone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_phone_btn">
            </FrameLayout>
        </FrameLayout>

        <!-- x2 passive boost -->
        <LinearLayout
            android:id="@+id/btnPassiveBoost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_boost_passive">
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>



    <FrameLayout
        android:id="@+id/progressBarContainer"
        android:layout_width="0dp"
        android:layout_height="16dp"
        android:layout_marginHorizontal="52dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/controlsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_loading"
            android:scaleType="fitXY" />

        <View
            android:id="@+id/whiteOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF" />
    </FrameLayout>

    <ImageView
        android:layout_width="26dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_x2"
        app:layout_constraintEnd_toEndOf="@id/progressBarContainer"
        app:layout_constraintTop_toTopOf="@id/progressBarContainer"
        app:layout_constraintBottom_toBottomOf="@id/progressBarContainer"
        android:layout_marginEnd="31dp"/>

    <ImageView
        android:layout_width="2dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_mark"
        android:id="@+id/markProgress"
        app:layout_constraintTop_toTopOf="@id/progressBarContainer"
        app:layout_constraintBottom_toBottomOf="@id/progressBarContainer"
        app:layout_constraintEnd_toEndOf="@id/progressBarContainer"
        android:layout_marginEnd="80dp"/>
        





    <!-- Bottom navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="0dp"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Shop -->
        <LinearLayout
            android:id="@+id/btnNavShop"
            android:layout_width="84dp"
            android:layout_height="90dp"
            android:layout_marginHorizontal="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_shop"
            android:gravity="center"
            android:orientation="vertical">
        </LinearLayout>

        <!-- Contacts -->
        <LinearLayout
            android:id="@+id/btnNavContacts"
            android:layout_width="84dp"
            android:layout_height="90dp"
            android:layout_marginHorizontal="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_contacts"
            android:gravity="center"
            android:orientation="vertical">
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/btnNavSettings"
            android:layout_width="84dp"
            android:layout_height="90dp"
            android:layout_marginHorizontal="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_setting"
            android:gravity="center"
            android:orientation="vertical">
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
