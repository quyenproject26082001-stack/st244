<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToOutline="false"
    android:background="@color/transparent"
    android:clipToPadding="false"
    tools:context=".ui.language.LanguageActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_bottom"
        app:layout_constraintTop_toTopOf="@id/btnBackLangSetting" />


    <TextView
        android:id="@+id/btnBackLangSetting"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/btnDoneLangSetting"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/ic_done_lang"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.temppp.core.custom.text.DoubleStrokeTextView
        android:id="@+id/tvLang"
        style="@style/single_marquee"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:fontFamily="@font/cherry_bomb_regular"
        android:gravity="center"
        android:paddingStart="10dp"
        android:text="@string/language"
        android:textColor="#7FC0FF"
        android:textSize="32sp"
        app:innerStrokeColor="@color/white"
        app:innerStrokeWidth="3dp"
        app:layout_constraintDimensionRatio="164:40"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBackLangSetting"
        app:outerStrokeColor="#00407F"
        app:outerStrokeWidth="10dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:overScrollMode="never"
        android:paddingHorizontal="20dp"
        android:paddingBottom="36dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/tvLang"
        tools:listitem="@layout/item_language" />

</androidx.constraintlayout.widget.ConstraintLayout>
